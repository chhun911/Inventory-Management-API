{
  "name": "inventory-management-selenium-tests",
  "private": true,
  "version": "0.1.0",
  "description": "Selenium WebDriver UI tests for the Vue frontend",
  "type": "module",
  "scripts": {
    "test": "mocha --recursive --timeout 30000 \"tests/**/*.spec.js\"",
    "test:headed": "HEADLESS=false mocha --recursive --timeout 30000 \"tests/**/*.spec.js\"",
    "test:auth": "mocha --timeout 30000 tests/auth.spec.js",
    "test:suppliers": "mocha --timeout 30000 tests/suppliers.spec.js",
    "test:errors": "mocha --timeout 30000 tests/errors.spec.js"
  },
  "devDependencies": {
    "chai": "^5.1.1",
    "dotenv": "^16.4.5",
    "mocha": "^8.1.3",
    "selenium-webdriver": "^4.21.0"
  }
}
